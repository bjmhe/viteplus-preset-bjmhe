{
  "name": "@bjmhe/viteplus-preset",
  "version": "1.0.10",
  "description": "A Vite Plus preset for creating a TypeScript package.",
  "keywords": [
    "package",
    "preset",
    "typescript",
    "vite",
    "vite-plus"
  ],
  "homepage": "https://github.com/bjmhe/viteplus-preset#readme",
  "bugs": {
    "url": "https://github.com/bjmhe/viteplus-preset/issues"
  },
  "license": "MIT",
  "author": "Benjamin He <hi@bjmhe.me>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bjmhe/viteplus-preset.git"
  },
  "files": [
    "dist",
    "README.md",
    "tsconfig.json"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "release": "bumpp",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@bjmhe/viteplus-preset-fmt": "latest",
    "@bjmhe/viteplus-preset-lint": "latest",
    "@bjmhe/viteplus-preset-pack": "latest",
    "tsdown": "^0.22.1"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260527.2",
    "@vitest/coverage-v8": "^4.1.7",
    "automd": "^0.4.3",
    "bumpp": "^11.1.0",
    "publint": "^0.3.21",
    "typescript": "^6.0.3",
    "unplugin-unused": "^0.5.7"
  },
  "peerDependencies": {
    "vite-plus": "^0.1.20"
  },
  "engines": {
    "node": ">=24.16.0"
  },
  "packageManager": "pnpm@11.4.0"
}
